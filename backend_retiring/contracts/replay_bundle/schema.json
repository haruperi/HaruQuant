{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ReplayBundle",
  "description": "Canonical contract for an immutable workflow reconstruction package.",
  "type": "object",
  "required": [
    "schema_version",
    "contract_type",
    "workflow_id",
    "correlation_id",
    "causation_id",
    "timestamp_utc",
    "originator",
    "environment",
    "operating_mode",
    "payload"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "contract_type": {
      "type": "string",
      "const": "ReplayBundle"
    },
    "workflow_id": {
      "type": "string",
      "minLength": 1
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1
    },
    "causation_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time"
    },
    "originator": {
      "type": "object",
      "required": ["type", "id"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["user", "agent", "service", "tool", "operator"]
        },
        "id": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "environment": {
      "type": "string",
      "enum": ["dev", "test", "paper", "staging", "prod"]
    },
    "operating_mode": {
      "type": "string",
      "enum": ["MODE-000", "MODE-001", "MODE-002", "MODE-003", "MODE-004"]
    },
    "payload": {
      "type": "object",
      "required": [
        "replay_bundle_id",
        "workflow_id",
        "completeness_status",
        "included_refs",
        "integrity_manifest",
        "export_profile",
        "generated_at"
      ],
      "properties": {
        "replay_bundle_id": {"type": "string", "minLength": 1},
        "workflow_id": {"type": "string", "minLength": 1},
        "completeness_status": {
          "type": "string",
          "enum": ["complete", "partial", "failed"]
        },
        "included_refs": {
          "type": "array",
          "items": {"type": "string"}
        },
        "integrity_manifest": {
          "type": "object",
          "required": ["manifest_hash", "manifest_algorithm"],
          "properties": {
            "manifest_hash": {"type": "string", "minLength": 1},
            "manifest_algorithm": {"type": "string", "minLength": 1}
          },
          "additionalProperties": false
        },
        "export_profile": {"type": "string", "minLength": 1},
        "generated_at": {"type": "string", "format": "date-time"}
      },
      "additionalProperties": false
    },
    "tenant_id": {"type": "string"},
    "account_scope_id": {"type": "string"},
    "strategy_scope_id": {"type": "string"},
    "compliance_profile_id": {"type": "string"},
    "content_hash": {"type": "string"},
    "signature": {"type": "string"},
    "trace_id": {"type": "string"},
    "replay_bundle_hint": {"type": "string"}
  },
  "additionalProperties": false
}
