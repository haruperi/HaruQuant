{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TradeProposal",
  "description": "Canonical contract for a validated transformation of a hypothesis toward risk review.",
  "type": "object",
  "required": [
    "schema_version",
    "contract_type",
    "workflow_id",
    "correlation_id",
    "causation_id",
    "timestamp_utc",
    "originator",
    "environment",
    "operating_mode",
    "payload"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "contract_type": {
      "type": "string",
      "const": "TradeProposal"
    },
    "workflow_id": {
      "type": "string",
      "minLength": 1
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1
    },
    "causation_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time"
    },
    "originator": {
      "type": "object",
      "required": ["type", "id"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["user", "agent", "service", "tool", "operator"]
        },
        "id": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "environment": {
      "type": "string",
      "enum": ["dev", "test", "paper", "staging", "prod"]
    },
    "operating_mode": {
      "type": "string",
      "enum": ["MODE-000", "MODE-001", "MODE-002", "MODE-003", "MODE-004"]
    },
    "payload": {
      "type": "object",
      "required": [
        "proposal_id",
        "source_hypothesis_id",
        "symbol",
        "direction",
        "candidate_price_logic",
        "proposed_size",
        "operating_envelope",
        "expiry_at",
        "transformation_version",
        "readiness_state"
      ],
      "properties": {
        "proposal_id": {"type": "string", "minLength": 1},
        "source_hypothesis_id": {"type": "string", "minLength": 1},
        "symbol": {"type": "string", "minLength": 1},
        "direction": {
          "type": "string",
          "enum": ["buy", "sell"]
        },
        "candidate_price_logic": {"type": "object"},
        "proposed_size": {"type": "object"},
        "operating_envelope": {"type": "object"},
        "session_restrictions": {"type": "object"},
        "expiry_at": {
          "type": "string",
          "format": "date-time"
        },
        "transformation_version": {"type": "string", "minLength": 1},
        "readiness_state": {
          "type": "string",
          "enum": ["draft", "validated", "ready_for_risk", "rejected"]
        }
      },
      "additionalProperties": false
    },
    "tenant_id": {"type": "string"},
    "account_scope_id": {"type": "string"},
    "strategy_scope_id": {"type": "string"},
    "compliance_profile_id": {"type": "string"},
    "content_hash": {"type": "string"},
    "signature": {"type": "string"},
    "trace_id": {"type": "string"},
    "replay_bundle_hint": {"type": "string"}
  },
  "additionalProperties": false
}
