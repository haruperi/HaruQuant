{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EvaluationReport",
  "description": "Canonical contract for a workflow or step evaluation result.",
  "type": "object",
  "required": [
    "schema_version",
    "contract_type",
    "workflow_id",
    "correlation_id",
    "causation_id",
    "timestamp_utc",
    "originator",
    "environment",
    "operating_mode",
    "payload"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "contract_type": {
      "type": "string",
      "const": "EvaluationReport"
    },
    "workflow_id": {
      "type": "string",
      "minLength": 1
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1
    },
    "causation_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time"
    },
    "originator": {
      "type": "object",
      "required": ["type", "id"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["user", "agent", "service", "tool", "operator"]
        },
        "id": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "environment": {
      "type": "string",
      "enum": ["dev", "test", "paper", "staging", "prod"]
    },
    "operating_mode": {
      "type": "string",
      "enum": ["MODE-000", "MODE-001", "MODE-002", "MODE-003", "MODE-004"]
    },
    "payload": {
      "type": "object",
      "required": [
        "evaluation_id",
        "target_type",
        "target_ref",
        "rubric_name",
        "rubric_scores",
        "overall_score",
        "verdict",
        "evaluator_identity",
        "evaluation_model_id"
      ],
      "properties": {
        "evaluation_id": {"type": "string", "minLength": 1},
        "target_type": {"type": "string", "minLength": 1},
        "target_ref": {"type": "string", "minLength": 1},
        "rubric_name": {"type": "string", "minLength": 1},
        "rubric_scores": {
          "type": "object",
          "additionalProperties": {"type": "number"}
        },
        "overall_score": {"type": "number"},
        "verdict": {
          "type": "string",
          "enum": ["pass", "warning", "fail"]
        },
        "issues": {
          "type": "array",
          "items": {"type": "string"}
        },
        "improvement_actions": {
          "type": "array",
          "items": {"type": "string"}
        },
        "evaluator_identity": {"type": "string", "minLength": 1},
        "evaluation_model_id": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "tenant_id": {"type": "string"},
    "account_scope_id": {"type": "string"},
    "strategy_scope_id": {"type": "string"},
    "compliance_profile_id": {"type": "string"},
    "content_hash": {"type": "string"},
    "signature": {"type": "string"},
    "trace_id": {"type": "string"},
    "replay_bundle_hint": {"type": "string"}
  },
  "additionalProperties": false
}
