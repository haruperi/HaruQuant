{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WorkflowIntent",
  "description": "Canonical contract for starting or resuming a workflow.",
  "type": "object",
  "required": [
    "schema_version",
    "contract_type",
    "workflow_id",
    "correlation_id",
    "causation_id",
    "timestamp_utc",
    "originator",
    "environment",
    "operating_mode",
    "payload"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "contract_type": {
      "type": "string",
      "const": "WorkflowIntent"
    },
    "workflow_id": {
      "type": "string",
      "minLength": 1
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1
    },
    "causation_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time"
    },
    "originator": {
      "type": "object",
      "required": ["type", "id"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["user", "agent", "service", "tool", "operator"]
        },
        "id": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "environment": {
      "type": "string",
      "enum": ["dev", "test", "paper", "staging", "prod"]
    },
    "operating_mode": {
      "type": "string",
      "enum": ["MODE-000", "MODE-001", "MODE-002", "MODE-003", "MODE-004"]
    },
    "payload": {
      "type": "object",
      "required": ["objective", "workflow_type", "trigger_type", "requested_scope"],
      "properties": {
        "objective": {
          "type": "string",
          "minLength": 1
        },
        "workflow_type": {
          "type": "string",
          "enum": [
            "trade_review",
            "portfolio_opt",
            "research_report",
            "paper_execution",
            "live_execution",
            "incident_triage",
            "promotion_review",
            "emergency_exit"
          ]
        },
        "trigger_type": {
          "type": "string",
          "enum": ["user_action", "schedule", "market_event", "internal_event"]
        },
        "requested_scope": {
          "type": "object"
        },
        "constraints": {
          "type": "object"
        },
        "permitted_tools": {
          "type": "array",
          "items": {"type": "string"}
        },
        "stop_conditions": {
          "type": "array",
          "items": {"type": "string"}
        },
        "timeout_policy": {
          "type": "object"
        },
        "evaluation_criteria": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": false
    },
    "tenant_id": {"type": "string"},
    "account_scope_id": {"type": "string"},
    "strategy_scope_id": {"type": "string"},
    "compliance_profile_id": {"type": "string"},
    "content_hash": {"type": "string"},
    "signature": {"type": "string"},
    "trace_id": {"type": "string"},
    "replay_bundle_hint": {"type": "string"}
  },
  "additionalProperties": false
}
