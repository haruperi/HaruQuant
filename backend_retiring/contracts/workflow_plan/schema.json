{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WorkflowPlan",
  "description": "Canonical contract for a formalized executable workflow plan.",
  "type": "object",
  "required": [
    "schema_version",
    "contract_type",
    "workflow_id",
    "correlation_id",
    "causation_id",
    "timestamp_utc",
    "originator",
    "environment",
    "operating_mode",
    "payload"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "contract_type": {
      "type": "string",
      "const": "WorkflowPlan"
    },
    "workflow_id": {
      "type": "string",
      "minLength": 1
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1
    },
    "causation_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time"
    },
    "originator": {
      "type": "object",
      "required": ["type", "id"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["user", "agent", "service", "tool", "operator"]
        },
        "id": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "environment": {
      "type": "string",
      "enum": ["dev", "test", "paper", "staging", "prod"]
    },
    "operating_mode": {
      "type": "string",
      "enum": ["MODE-000", "MODE-001", "MODE-002", "MODE-003", "MODE-004"]
    },
    "payload": {
      "type": "object",
      "required": [
        "plan_id",
        "selected_pattern",
        "phase_steps"
      ],
      "properties": {
        "plan_id": {
          "type": "string",
          "minLength": 1
        },
        "selected_pattern": {
          "type": "string",
          "enum": [
            "sequential",
            "routing",
            "parallel",
            "evaluator_optimizer",
            "orchestrator_workers"
          ]
        },
        "phase_steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "phase",
              "owner_agent",
              "expected_output_contract_type"
            ],
            "properties": {
              "step_id": {
                "type": "string"
              },
              "phase": {
                "type": "string",
                "minLength": 1
              },
              "owner_agent": {
                "type": "string",
                "minLength": 1
              },
              "goal": {
                "type": "string",
                "minLength": 1
              },
              "input_contract_type": {
                "type": "string",
                "minLength": 1
              },
              "expected_output_contract_type": {
                "type": "string",
                "minLength": 1
              },
              "depends_on": {
                "type": "array",
                "items": {"type": "string"}
              },
              "allowed_tools": {
                "type": "array",
                "items": {"type": "string"}
              },
              "timeout_seconds": {
                "type": "integer",
                "minimum": 1
              },
              "failure_policy": {
                "type": "object",
                "properties": {
                  "retry_count": {"type": "integer", "minimum": 0},
                  "timeout_seconds": {"type": "integer", "minimum": 1},
                  "fallback_agent": {"type": "string", "minLength": 1},
                  "compensation_action": {"type": "string", "minLength": 1},
                  "escalation_condition": {"type": "string", "minLength": 1},
                  "critical": {"type": "boolean"}
                },
                "additionalProperties": false
              },
              "metadata": {
                "type": "object"
              }
            },
            "additionalProperties": false
          }
        },
        "assigned_agents": {
          "type": "array",
          "items": {"type": "string"}
        },
        "tool_permissions": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {"type": "string"}
          }
        },
        "success_conditions": {
          "type": "array",
          "items": {"type": "string"}
        },
        "escalation_conditions": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": false
    },
    "tenant_id": {"type": "string"},
    "account_scope_id": {"type": "string"},
    "strategy_scope_id": {"type": "string"},
    "compliance_profile_id": {"type": "string"},
    "content_hash": {"type": "string"},
    "signature": {"type": "string"},
    "trace_id": {"type": "string"},
    "replay_bundle_hint": {"type": "string"}
  },
  "additionalProperties": false
}
