{
  "$id": "https://haruquant.local/schemas/chat_tool_attachment/1.0.0.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Chat Tool Attachment",
  "description": "Allowlisted tool attached to a HaruQuant AI chat turn or thread.",
  "type": "object",
  "properties": {
    "tool_id": { "type": "string", "minLength": 1 },
    "display_name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "capability_type": {
      "type": "string",
      "enum": [
        "strategy_creation",
        "strategy_refinement",
        "backtest_analysis",
        "optimization_comparison",
        "risk_review",
        "signal_proposal",
        "page_operation",
        "knowledge_retrieval"
      ]
    },
    "authority_band": { "type": "string", "minLength": 1 },
    "side_effect_policy": {
      "type": "string",
      "enum": ["read_only", "artifact_only", "approval_gate", "draft_action", "page_action_plan"]
    },
    "input_schema": { "type": "object" },
    "output_schema": { "type": "object" },
    "required_context": {
      "type": "array",
      "items": { "type": "string" }
    },
    "allowed_backend_tools": {
      "type": "array",
      "items": { "type": "string" }
    },
    "allowed_specialist_agents": {
      "type": "array",
      "items": { "type": "string" }
    },
    "system_prompt_fragment": { "type": "string", "minLength": 1 },
    "response_template": { "type": ["string", "null"] },
    "artifact_type": { "type": ["string", "null"] },
    "required_user_ack": { "type": "boolean" }
  },
  "required": [
    "tool_id",
    "display_name",
    "capability_type",
    "authority_band",
    "side_effect_policy",
    "system_prompt_fragment"
  ],
  "additionalProperties": false
}
