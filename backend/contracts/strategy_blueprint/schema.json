{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StrategyBlueprint",
  "description": "Canonical contract for a complete, backtest-ready strategy design blueprint.",
  "type": "object",
  "required": [
    "schema_version",
    "contract_type",
    "workflow_id",
    "correlation_id",
    "causation_id",
    "timestamp_utc",
    "originator",
    "environment",
    "operating_mode",
    "payload"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "contract_type": { "type": "string", "const": "StrategyBlueprint" },
    "workflow_id": { "type": "string", "minLength": 1 },
    "correlation_id": { "type": "string", "minLength": 1 },
    "causation_id": { "type": "string", "minLength": 1 },
    "timestamp_utc": { "type": "string", "format": "date-time" },
    "originator": {
      "type": "object",
      "required": ["type", "id"],
      "properties": {
        "type": { "type": "string", "enum": ["user", "agent", "service", "tool", "operator"] },
        "id": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "environment": { "type": "string", "enum": ["dev", "test", "paper", "staging", "prod"] },
    "operating_mode": { "type": "string", "enum": ["MODE-000", "MODE-001", "MODE-002", "MODE-003", "MODE-004"] },
    "payload": {
      "type": "object",
      "required": [
        "strategy_id",
        "strategy_name",
        "source_idea",
        "strategy_type",
        "asset_scope",
        "entry_logic",
        "exit_logic",
        "risk_management",
        "position_sizing",
        "assumptions_applied",
        "assumption_defaults_used",
        "backtest_readiness",
        "render_target"
      ],
      "properties": {
        "strategy_id": { "type": "string", "minLength": 1 },
        "strategy_name": { "type": "string", "minLength": 1 },
        "source_idea": { "type": "string", "minLength": 1 },
        "strategy_type": {
          "type": "string",
          "enum": ["technical", "portfolio", "ml", "factor", "stat_arb", "allocation", "rotation"]
        },
        "asset_scope": {
          "type": "object",
          "required": ["assets", "timeframe", "data_granularity"],
          "properties": {
            "assets": { "type": "array", "minItems": 1, "items": { "type": "string" } },
            "timeframe": { "type": "string", "minLength": 1 },
            "data_granularity": { "type": "string", "minLength": 1 },
            "asset_notes": { "type": "string" }
          },
          "additionalProperties": false
        },
        "entry_logic": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "exit_logic": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "risk_management": {
          "type": "object",
          "required": ["ignore_stop_loss_take_profit", "additional_rules"],
          "properties": {
            "stop_loss": { "type": "string" },
            "take_profit": { "type": "string" },
            "ignore_stop_loss_take_profit": { "type": "boolean" },
            "additional_rules": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        },
        "position_sizing": {
          "type": "object",
          "required": ["sizing_rule", "leverage"],
          "properties": {
            "sizing_rule": { "type": "string", "minLength": 1 },
            "leverage": { "type": "number", "minimum": 0.0 },
            "allocation_notes": { "type": "string" }
          },
          "additionalProperties": false
        },
        "model_spec": {
          "type": "object",
          "required": ["model_type", "target_definition", "feature_set", "prediction_horizon"],
          "properties": {
            "model_type": { "type": "string", "minLength": 1 },
            "target_definition": { "type": "string", "minLength": 1 },
            "feature_set": { "type": "array", "items": { "type": "string" } },
            "prediction_horizon": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "portfolio_construction": {
          "type": "object",
          "required": ["method", "rebalance_frequency", "objective"],
          "properties": {
            "method": { "type": "string", "minLength": 1 },
            "rebalance_frequency": { "type": "string", "minLength": 1 },
            "objective": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "assumptions_applied": { "type": "array", "items": { "type": "string" } },
        "assumption_defaults_used": { "type": "array", "items": { "type": "string" } },
        "backtest_readiness": { "type": "string", "enum": ["ready", "needs_review"] },
        "render_target": { "type": "string", "const": "template_strategy" }
      },
      "additionalProperties": false
    },
    "tenant_id": { "type": "string" },
    "account_scope_id": { "type": "string" },
    "strategy_scope_id": { "type": "string" },
    "compliance_profile_id": { "type": "string" },
    "content_hash": { "type": "string" },
    "signature": { "type": "string" },
    "trace_id": { "type": "string" },
    "replay_bundle_hint": { "type": "string" }
  },
  "additionalProperties": false
}
