{
  "$id": "https://haruquant.local/schemas/chat_artifact/1.0.0.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Chat Artifact",
  "description": "Validated artifact produced by a HaruQuant AI chat tool or specialist agent.",
  "type": "object",
  "properties": {
    "artifact_id": { "type": "string", "minLength": 1 },
    "artifact_type": { "type": "string", "minLength": 1 },
    "tool_id": { "type": ["string", "null"] },
    "agent_name": { "type": ["string", "null"] },
    "thread_id": { "type": ["string", "null"] },
    "message_id": { "type": ["string", "null"] },
    "status": {
      "type": "string",
      "enum": ["draft", "validated", "needs_review", "rejected", "materialized"]
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    },
    "validation": {
      "type": "object",
      "properties": {
        "valid": { "type": "boolean" },
        "issues": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["valid", "issues"],
      "additionalProperties": false
    },
    "created_at": { "type": "string" }
  },
  "required": ["artifact_id", "artifact_type", "status", "payload", "validation", "created_at"],
  "additionalProperties": false
}
