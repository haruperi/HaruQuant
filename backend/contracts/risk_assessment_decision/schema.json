{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RiskAssessmentDecision",
  "description": "Canonical contract for a deterministic risk decision and mandatory execution gate.",
  "type": "object",
  "required": [
    "schema_version",
    "contract_type",
    "workflow_id",
    "correlation_id",
    "causation_id",
    "timestamp_utc",
    "originator",
    "environment",
    "operating_mode",
    "payload"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "contract_type": {
      "type": "string",
      "const": "RiskAssessmentDecision"
    },
    "workflow_id": {
      "type": "string",
      "minLength": 1
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1
    },
    "causation_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time"
    },
    "originator": {
      "type": "object",
      "required": ["type", "id"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["user", "agent", "service", "tool", "operator"]
        },
        "id": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "environment": {
      "type": "string",
      "enum": ["dev", "test", "paper", "staging", "prod"]
    },
    "operating_mode": {
      "type": "string",
      "enum": ["MODE-000", "MODE-001", "MODE-002", "MODE-003", "MODE-004"]
    },
    "payload": {
      "type": "object",
      "required": [
        "risk_decision_id",
        "proposal_id",
        "decision",
        "reasons",
        "risk_metrics_snapshot",
        "freshness_expiry",
        "policy_version",
        "formula_version",
        "provenance_bundle_ref"
      ],
      "properties": {
        "risk_decision_id": {"type": "string", "minLength": 1},
        "proposal_id": {"type": "string", "minLength": 1},
        "decision": {
          "type": "string",
          "enum": ["APPROVE", "APPROVE_WITH_LIMITS", "REJECT", "FORCE_EXIT"]
        },
        "reasons": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        },
        "limit_constraints": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["constraint_type", "value"],
            "properties": {
              "constraint_type": {"type": "string", "minLength": 1},
              "value": {
                "type": "object",
                "additionalProperties": {"type": "number"}
              }
            },
            "additionalProperties": false
          }
        },
        "risk_metrics_snapshot": {
          "type": "object",
          "additionalProperties": {"type": "number"}
        },
        "freshness_expiry": {
          "type": "string",
          "format": "date-time"
        },
        "policy_version": {"type": "string", "minLength": 1},
        "formula_version": {"type": "string", "minLength": 1},
        "provenance_bundle_ref": {
          "type": "object",
          "required": ["bundle_id", "account_snapshot_ref", "market_snapshot_ref"],
          "properties": {
            "bundle_id": {"type": "string", "minLength": 1},
            "account_snapshot_ref": {"type": "string", "minLength": 1},
            "market_snapshot_ref": {"type": "string", "minLength": 1}
          },
          "additionalProperties": false
        },
        "approval_token": {"type": "string"},
        "force_exit_symbols": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": false
    },
    "tenant_id": {"type": "string"},
    "account_scope_id": {"type": "string"},
    "strategy_scope_id": {"type": "string"},
    "compliance_profile_id": {"type": "string"},
    "content_hash": {"type": "string"},
    "signature": {"type": "string"},
    "trace_id": {"type": "string"},
    "replay_bundle_hint": {"type": "string"}
  },
  "additionalProperties": false
}
