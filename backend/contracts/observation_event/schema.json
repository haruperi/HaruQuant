{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ObservationEvent",
  "description": "Canonical contract for an observed state change, tool output, or environment signal.",
  "type": "object",
  "required": [
    "schema_version",
    "contract_type",
    "workflow_id",
    "correlation_id",
    "causation_id",
    "timestamp_utc",
    "originator",
    "environment",
    "operating_mode",
    "payload"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "contract_type": {
      "type": "string",
      "const": "ObservationEvent"
    },
    "workflow_id": {
      "type": "string",
      "minLength": 1
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1
    },
    "causation_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time"
    },
    "originator": {
      "type": "object",
      "required": ["type", "id"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["user", "agent", "service", "tool", "operator"]
        },
        "id": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "environment": {
      "type": "string",
      "enum": ["dev", "test", "paper", "staging", "prod"]
    },
    "operating_mode": {
      "type": "string",
      "enum": ["MODE-000", "MODE-001", "MODE-002", "MODE-003", "MODE-004"]
    },
    "payload": {
      "type": "object",
      "required": [
        "observation_id",
        "observation_type",
        "severity",
        "source",
        "payload_ref_or_inline",
        "authority_state",
        "freshness_status",
        "observed_at"
      ],
      "properties": {
        "observation_id": {"type": "string", "minLength": 1},
        "observation_type": {"type": "string", "minLength": 1},
        "severity": {
          "type": "string",
          "enum": ["info", "warning", "critical"]
        },
        "source": {"type": "string", "minLength": 1},
        "payload_ref_or_inline": {"type": "object"},
        "authority_state": {"type": "object"},
        "freshness_status": {
          "type": "string",
          "enum": ["fresh", "stale", "unknown"]
        },
        "observed_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "tenant_id": {"type": "string"},
    "account_scope_id": {"type": "string"},
    "strategy_scope_id": {"type": "string"},
    "compliance_profile_id": {"type": "string"},
    "content_hash": {"type": "string"},
    "signature": {"type": "string"},
    "trace_id": {"type": "string"},
    "replay_bundle_hint": {"type": "string"}
  },
  "additionalProperties": false
}
