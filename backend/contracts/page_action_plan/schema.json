{
  "$id": "https://haruquant.local/schemas/page_action_plan/1.0.0.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Page Action Plan",
  "description": "Governed plan to execute a UI action on behalf of the user",
  "type": "object",
  "properties": {
    "contract_type": {
      "type": "string",
      "const": "PageActionPlan"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "action_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "risk_level": {
      "type": "string",
      "enum": ["view_only", "local_ui", "backend_safe", "backend_risk"]
    },
    "parameters": {
      "type": "object",
      "additionalProperties": true
    },
    "reasoning": {
      "type": "string"
    }
  },
  "required": [
    "contract_type",
    "schema_version",
    "action_id",
    "risk_level",
    "parameters",
    "reasoning"
  ],
  "additionalProperties": false
}
